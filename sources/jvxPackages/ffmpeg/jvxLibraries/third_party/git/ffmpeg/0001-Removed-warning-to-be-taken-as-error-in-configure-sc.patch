From 31c8d57beedfecb7563c685467f016ed76d92efb Mon Sep 17 00:00:00 2001
From: unknown <hk@binauricsaudio.com>
Date: Tue, 5 May 2026 21:49:12 +0200
Subject: [PATCH] Removed warning to be taken as error in configure script.
 otherwise, x264 and x265 would not build

---
 configure | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/configure b/configure
index 9bce658932..579c0ad141 100755
--- a/configure
+++ b/configure
@@ -1308,7 +1308,7 @@ test_ld(){
     # link.exe and lld-link exit 0 even for unrecognized options, emitting
     # only a warning (LNK4044 / "ignoring unknown argument").  Treat such
     # output as failure so check_ldflags rejects those flags correctly.
-    test $ret -eq 0 && ! echo "$output" | grep -qE 'LNK4044|lld-link: warning: ignoring unknown argument'
+    test $ret -eq 0 # && ! echo "$output" | grep -qE 'LNK4044|lld-link: warning: ignoring unknown argument'
 }
 
 check_ld(){
-- 
2.47.1.windows.1

